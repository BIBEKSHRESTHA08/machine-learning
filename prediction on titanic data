import pandas as pd
from sklearn.ensemble import RandomForestClassifier
import seaborn as sns
import matplotlib.pyplot as plt
import numpy as np

# Load the files (they must be in the same folder as this .py file)
train_data = pd.read_csv('train.csv')
test_data = pd.read_csv('test.csv')
print(train_data.head())

# Check missing values BEFORE
print("Missing values before:")
print(train_data[['Age', 'Fare']].isnull().sum())

# Fill missing values with median
train_data['Age'] = train_data['Age'].fillna(train_data['Age'].median())
test_data['Age'] = test_data['Age'].fillna(test_data['Age'].median())
test_data['Fare'] = test_data['Fare'].fillna(test_data['Fare'].median())

print("\nMissing values after:")
print(train_data[['Age', 'Fare']].isnull().sum())

# ✅ Plot BEFORE encoding Sex (so chart shows male/female labels)
sns.set_theme(style="whitegrid")
f, ax = plt.subplots(1, 2, figsize=(12, 5))
sns.barplot(x="Sex", y="Survived", data=train_data, ax=ax[0])
ax[0].set_title('Survival Rate by Gender')
sns.barplot(x="Pclass", y="Survived", data=train_data, ax=ax[1])
ax[1].set_title('Survival Rate by Passenger Class')
plt.show()

plt.figure(figsize=(10, 5))
sns.histplot(data=train_data, x="Age", hue="Survived", kde=True, element="step")
plt.title('Age Distribution: Survived vs Deceased')
plt.show()

# Encode Sex AFTER plotting
train_data['Sex'] = train_data['Sex'].map({'male': 0, 'female': 1})
test_data['Sex'] = test_data['Sex'].map({'male': 0, 'female': 1})

# Train model
features = ["Pclass", "Sex", "Age", "SibSp", "Parch", "Fare"]
X = train_data[features]
y = train_data["Survived"]
X_test = test_data[features]

model = RandomForestClassifier(n_estimators=100, max_depth=5, random_state=1)
model.fit(X, y)
print("Model training complete.")

# Feature importance chart
importances = model.feature_importances_
indices = np.argsort(importances)
plt.figure(figsize=(10, 5))
plt.title('Which features did the model care about most?')
plt.barh(range(len(indices)), importances[indices], align='center')
plt.yticks(range(len(indices)), [features[i] for i in indices])
plt.xlabel('Importance Score')
plt.show()

# Save predictions
predictions = model.predict(X_test)
output = pd.DataFrame({'PassengerId': test_data.PassengerId, 'Survived': predictions})
output.to_csv('my_first_submission.csv', index=False)
print("Done! Submission saved as my_first_submission.csv")
print(output.head(10))
